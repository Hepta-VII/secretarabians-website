  "home": {
    "hero": {
      "title": "\u0633\u064a\u0643\u0631\u062a \u0623\u0631\u0627\u0628\u064a\u0627\u0646\u0632",
      "subtitle": "\u062a\u0631\u0628\u064a\u0629 \u062e\u064a\u0648\u0644 \u0639\u0631\u0628\u064a\u0629 \u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u0629 \u062a\u0644\u0647\u0645 \u0627\u0644\u0639\u0627\u0644\u0645",
      "welcome": "\u0645\u0631\u062d\u0628\u0627\u064b \u0628\u0643\u0645 \u0641\u064a",
      "tagline": "\u0631\u062d\u0644\u0629 \u064a\u0642\u0648\u062f\u0647\u0627 \u0627\u0644\u0634\u063a\u0641\u060c \u064a\u0634\u0643\u0644\u0647\u0627 \u0627\u0644\u062d\u0628\u060c \u0648\u062a\u064f\u0628\u0646\u0649 \u0639\u0644\u0649 \u062d\u0644\u0645."
    },
    "testimonial": {
      "quote": "\u0646\u0624\u0645\u0646 \u0628\u0623\u0646 \u0627\u0644\u062e\u064a\u0648\u0644 \u0627\u0644\u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u0629 \u062d\u0642\u0627\u064b \u062a\u064f\u0635\u0627\u063a \u0628\u0627\u0644\u062d\u0628 \u0648\u0627\u0644\u0645\u0639\u0627\u064a\u064a\u0631 \u0627\u0644\u0635\u0627\u0631\u0645\u0629. \u0643\u0644 \u062a\u0641\u0635\u064a\u0644 \u0645\u0647\u0645\u060c \u0643\u0644 \u0642\u0631\u0627\u0631 \u064a\u064f\u062d\u0633\u0628\u060c \u0648\u0644\u0627 \u0634\u064a\u0621 \u064a\u064f\u062a\u0631\u0643 \u0644\u0644\u0635\u062f\u0641\u0629. \u0639\u064a\u0646\u0646\u0627 \u0627\u0644\u062b\u0627\u0642\u0628\u0629 \u0644\u0644\u0643\u0645\u0627\u0644 \u0648\u062a\u0641\u0627\u0646\u064a\u0646\u0627 \u0627\u0644\u0631\u0627\u0633\u062e \u064a\u0646\u0639\u0643\u0633\u0627\u0646 \u0641\u064a \u0643\u0644 \u062d\u0635\u0627\u0646 \u0646\u0631\u0628\u064a\u0647."
    },
    "dream": {
      "title": "\u062d\u0644\u0645 \u0646\u062a\u0634\u0627\u0631\u0643\u0647 \u0645\u0639\u0643\u0645",
      "body": "\u0645\u0627 \u0628\u062f\u0623 \u0643\u062d\u0644\u0645 \u0623\u0635\u0628\u062d \u0634\u063a\u0641 \u062d\u064a\u0627\u062a\u0646\u0627. \u0641\u064a \u0633\u064a\u0643\u0631\u062a \u0623\u0631\u0627\u0628\u064a\u0627\u0646\u0632\u060c \u0646\u0631\u0628\u064a \u062e\u064a\u0648\u0644\u0627\u064b \u0639\u0631\u0628\u064a\u0629 \u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u0629 \u062d\u0642\u0627\u064b. \u062d\u0628\u0646\u0627 \u0627\u0644\u0639\u0645\u064a\u0642 \u0644\u0644\u0633\u0644\u0627\u0644\u0629 \u0648\u0633\u0639\u064a\u0646\u0627 \u0627\u0644\u062f\u0624\u0648\u0628 \u0644\u0644\u062a\u0645\u064a\u0632 \u064a\u062f\u0641\u0639\u0627\u0646\u0646\u0627 \u0644\u0644\u062a\u0639\u0644\u0645 \u0648\u0627\u0644\u062a\u0637\u0648\u0631 \u0628\u0627\u0633\u062a\u0645\u0631\u0627\u0631. \u0643\u0644 \u062c\u064a\u0644 \u064a\u0642\u0631\u0628\u0646\u0627 \u0623\u0643\u062b\u0631 \u0645\u0646 \u0631\u0624\u064a\u062a\u0646\u0627 \u0641\u064a \u062a\u0631\u0628\u064a\u0629 \u062e\u064a\u0648\u0644 \u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u0629 \u062a\u0644\u0647\u0645 \u0627\u0644\u0639\u0627\u0644\u0645 \u0648\u062a\u062a\u0631\u0643 \u0625\u0631\u062b\u0627\u064b \u062e\u0627\u0644\u062f\u0627\u064b."
    },
    "pillars": {
      "excellence": {
        "title": "\u0627\u0644\u0633\u0639\u064a \u0646\u062d\u0648 \u0627\u0644\u062a\u0645\u064a\u0632",
        "body": "\u0646\u0631\u0641\u0636 \u0627\u0644\u0642\u0628\u0648\u0644 \u0628\u0627\u0644\u0639\u0627\u062f\u064a. \u0646\u062e\u062a\u0627\u0631 \u0641\u0642\u0637 \u0623\u0631\u0642\u0649 \u0627\u0644\u0633\u0644\u0627\u0644\u0627\u062a \u0648\u0646\u0643\u0631\u0633 \u0623\u0646\u0641\u0633\u0646\u0627 \u0644\u062a\u0631\u0628\u064a\u0629 \u062e\u064a\u0648\u0644 \u062a\u062a\u0645\u064a\u0632 \u0628\u0627\u0644\u062c\u0645\u0627\u0644 \u0648\u0627\u0644\u062d\u0636\u0648\u0631 \u0648\u0627\u0644\u0634\u062e\u0635\u064a\u0629."
      },
      "care": {
        "title": "\u0623\u0631\u0642\u0649 \u0631\u0639\u0627\u064a\u0629",
        "body": "\u062a\u062d\u0638\u0649 \u062e\u064a\u0648\u0644\u0646\u0627 \u0628\u0623\u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u064a\u0627\u062a \u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0648\u0627\u0644\u0631\u0627\u062d\u0629 \u0648\u0627\u0644\u0627\u0647\u062a\u0645\u0627\u0645 \u0641\u064a \u062c\u0645\u064a\u0639 \u0627\u0644\u0623\u0648\u0642\u0627\u062a. \u0646\u0624\u0645\u0646 \u0628\u0623\u0646 \u0627\u0644\u062e\u064a\u0648\u0644 \u0627\u0644\u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u0629 \u062a\u0632\u062f\u0647\u0631 \u0628\u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0645\u062e\u0644\u0635\u0629 \u0648\u0627\u0644\u062d\u0628 \u0648\u062d\u064a\u0627\u0629 \u0645\u0644\u064a\u0626\u0629 \u0628\u0627\u0644\u0633\u0639\u0627\u062f\u0629."
      },
      "learning": {
        "title": "\u062a\u0639\u0644\u0645 \u0645\u062f\u0649 \u0627\u0644\u062d\u064a\u0627\u0629",
        "body": "\u0646\u0635\u0642\u0644 \u0646\u0647\u062c\u0646\u0627 \u0628\u0627\u0633\u062a\u0645\u0631\u0627\u0631\u060c \u0648\u0646\u062a\u0628\u0646\u0649 \u0631\u0624\u0649 \u062c\u062f\u064a\u062f\u0629\u060c \u0648\u0646\u062a\u062d\u062f\u0649 \u0623\u0646\u0641\u0633\u0646\u0627 \u0644\u0644\u0646\u0645\u0648. \u0643\u0644 \u062a\u062c\u0631\u0628\u0629 \u062a\u0634\u0643\u0644\u0646\u0627 \u0643\u0645\u0631\u0628\u064a\u0646 \u0623\u0641\u0636\u0644 \u0648\u062a\u0642\u0631\u0628\u0646\u0627 \u0645\u0646 \u0631\u0624\u064a\u062a\u0646\u0627."
      }
    },
    "cta": {
      "title": "\u0642\u0644\u0628 \u062d\u0644\u0645\u0646\u0627",
      "body": "\u0647\u0644 \u0623\u0646\u062a\u0645 \u0645\u0633\u062a\u0639\u062f\u0648\u0646 \u0644\u0644\u0642\u0627\u0621 \u062e\u064a\u0648\u0644\u0646\u0627\u061f \u0643\u0644 \u0648\u0627\u062d\u062f \u0645\u0646\u0647\u0627 \u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u060c \u0643\u0644 \u0648\u0627\u062d\u062f \u0631\u064f\u0628\u0651\u064a \u0644\u064a\u0644\u0647\u0645. \u062a\u0639\u0631\u0641\u0648\u0627 \u0639\u0644\u064a\u0647\u0645 \u0648\u0627\u0643\u062a\u0634\u0641\u0648\u0627 \u0645\u0627 \u064a\u062c\u0639\u0644\u0647\u0645 \u0645\u0645\u064a\u0632\u064a\u0646.",
      "button": "\u0627\u0643\u062a\u0634\u0641 \u062e\u064a\u0648\u0644\u0646\u0627"
    }
  },
  "metadata": {
    "title": "\u0633\u064a\u0643\u0631\u062a \u0623\u0631\u0627\u0628\u064a\u0627\u0646\u0632",
    "description": "\u062a\u0631\u0628\u064a\u0629 \u062e\u064a\u0648\u0644 \u0639\u0631\u0628\u064a\u0629 \u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u0629 \u062a\u0644\u0647\u0645 \u0627\u0644\u0639\u0627\u0644\u0645. \u0628\u0631\u0646\u0627\u0645\u062c \u062a\u0631\u0628\u064a\u0629 \u062e\u064a\u0648\u0644 \u0639\u0631\u0628\u064a\u0629 \u0645\u062a\u0645\u064a\u0632 \u0645\u062e\u0635\u0635 \u0644\u062a\u0631\u0628\u064a\u0629 \u062e\u064a\u0648\u0644 \u0639\u0631\u0628\u064a\u0629 \u0630\u0627\u062a \u062c\u0648\u062f\u0629 \u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u0629."
  }
