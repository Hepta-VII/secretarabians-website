  "home": {
    "hero": {
      "title": "Secret Arabians",
      "subtitle": "\u57f9\u80b2\u6fc0\u52b1\u4e16\u754c\u7684\u975e\u51e1\u963f\u62c9\u4f2f\u9a6c",
      "welcome": "\u6b22\u8fce\u6765\u5230",
      "tagline": "\u4e00\u6bb5\u7531\u6fc0\u60c5\u9a71\u52a8\u3001\u7531\u7231\u5851\u9020\u3001\u5efa\u7acb\u5728\u68a6\u60f3\u4e4b\u4e0a\u7684\u65c5\u7a0b\u3002"
    },
    "testimonial": {
      "quote": "\u6211\u4eec\u76f8\u4fe1\uff0c\u771f\u6b63\u5353\u8d8a\u7684\u9a6c\u5339\u662f\u7531\u7231\u548c\u4e25\u683c\u7684\u6807\u51c6\u5851\u9020\u7684\u3002\u6bcf\u4e00\u4e2a\u7ec6\u8282\u90fd\u5f88\u91cd\u8981\uff0c\u6bcf\u4e00\u4e2a\u51b3\u5b9a\u90fd\u81f3\u5173\u91cd\u8981\uff0c\u6ca1\u6709\u4efb\u4f55\u4e8b\u60c5\u662f\u5076\u7136\u7684\u3002\u6211\u4eec\u5bf9\u5b8c\u7f8e\u7684\u8ffd\u6c42\u548c\u575a\u5b9a\u4e0d\u79fb\u7684\u5949\u732e\u7cbe\u795e\u4f53\u73b0\u5728\u6211\u4eec\u57f9\u80b2\u7684\u6bcf\u4e00\u5339\u9a6c\u4e0a\u3002"
    },
    "dream": {
      "title": "\u4e0e\u60a8\u5206\u4eab\u7684\u68a6\u60f3",
      "body": "\u4ece\u68a6\u60f3\u5f00\u59cb\uff0c\u5df2\u6210\u4e3a\u6211\u4eec\u6bd5\u751f\u7684\u70ed\u60c5\u3002\u5728 Secret Arabians\uff0c\u6211\u4eec\u57f9\u80b2\u771f\u6b63\u5353\u8d8a\u7684\u963f\u62c9\u4f2f\u9a6c\u3002\u6211\u4eec\u5bf9\u8fd9\u4e2a\u54c1\u79cd\u7684\u6df1\u539a\u70ed\u7231\u548c\u5bf9\u5353\u8d8a\u7684\u4e0d\u61c8\u8ffd\u6c42\u9a71\u52a8\u6211\u4eec\u4e0d\u65ad\u5b66\u4e60\u548c\u8fdb\u6b65\u3002\u6bcf\u4e00\u4ee3\u90fd\u8ba9\u6211\u4eec\u66f4\u63a5\u8fd1\u57f9\u80b2\u975e\u51e1\u9a6c\u5339\u7684\u613f\u666f\uff0c\u6fc0\u52b1\u4e16\u754c\uff0c\u7559\u4e0b\u6c38\u6052\u7684\u9057\u4ea7\u3002"
    },
    "pillars": {
      "excellence": {
        "title": "\u8ffd\u6c42\u5353\u8d8a",
        "body": "\u6211\u4eec\u62d2\u7edd\u5e73\u5eb8\u3002\u53ea\u6709\u6700\u4f18\u79c0\u7684\u8840\u7edf\u88ab\u9009\u4e2d\uff0c\u6211\u4eec\u81f4\u529b\u4e8e\u57f9\u80b2\u5728\u7f8e\u4e3d\u3001\u6c14\u8d28\u548c\u6027\u683c\u4e0a\u8131\u9896\u800c\u51fa\u7684\u9a6c\u5339\u3002"
      },
      "care": {
        "title": "\u81f3\u81fb\u5173\u6000",
        "body": "\u6211\u4eec\u7684\u9a6c\u5339\u59cb\u7ec8\u4eab\u53d7\u6700\u9ad8\u6807\u51c6\u7684\u7167\u6599\u3001\u8212\u9002\u548c\u5173\u6ce8\u3002\u6211\u4eec\u76f8\u4fe1\uff0c\u5353\u8d8a\u7684\u9a6c\u5339\u5728\u5c3d\u5fc3\u7684\u5173\u7231\u548c\u5145\u6ee1\u5e78\u798f\u7684\u751f\u6d3b\u4e2d\u7efd\u653e\u5149\u5f69\u3002"
      },
      "learning": {
        "title": "\u7ec8\u8eab\u5b66\u4e60",
        "body": "\u6211\u4eec\u4e0d\u65ad\u5b8c\u5584\u65b9\u6cd5\uff0c\u62e5\u62b1\u65b0\u89c1\u89e3\uff0c\u6311\u6218\u81ea\u6211\u6210\u957f\u3002\u6bcf\u4e00\u6b21\u7ecf\u5386\u90fd\u5851\u9020\u6211\u4eec\u6210\u4e3a\u66f4\u597d\u7684\u80b2\u9a6c\u8005\uff0c\u8ba9\u6211\u4eec\u66f4\u63a5\u8fd1\u613f\u666f\u3002"
      }
    },
    "cta": {
      "title": "\u6211\u4eec\u68a6\u60f3\u7684\u6838\u5fc3",
      "body": "\u51c6\u5907\u597d\u8ba4\u8bc6\u6211\u4eec\u7684\u9a6c\u5339\u4e86\u5417\uff1f\u6bcf\u4e00\u5339\u90fd\u662f\u5353\u8d8a\u7684\uff0c\u6bcf\u4e00\u5339\u90fd\u88ab\u57f9\u80b2\u4e3a\u6fc0\u52b1\u4eba\u5fc3\u3002\u4e86\u89e3\u5b83\u4eec\uff0c\u53d1\u73b0\u5b83\u4eec\u7684\u72ec\u7279\u4e4b\u5904\u3002",
      "button": "\u53d1\u73b0\u6211\u4eec\u7684\u9a6c\u5339"
    }
  },
  "about": {
    "hero": {
      "title": "我们的故事",
      "tagline": "从童年的梦想到我们今天的生活。"
    },
    "paradise": {
      "title": "小女孩的天堂",
      "body": "在Secret Arabians诞生之前很久，有一个小女孩在祖父母的马厩里，无法远离马匹。对我来说，那是世界上最美丽的地方，我自己的小天堂。正是在那里，我第一次遇到了阿拉伯马，一个永远改变了我生命的品种。我爱上了它们的优雅、精神，以及它们与你在更深层次上建立联系的方式。这份爱从未离开过我，多年来它成长为终身的热情，最终成为Secret Arabians的核心。"
    },
    "meant": {
      "title": "命中注定",
      "body": "2023年，多年的梦想终于变成了现实。Rector's Calista，一匹我认识和欣赏多年的马，出乎意料地成为了我的。作为我们的第一匹繁殖母马，她是点燃Secret Arabians生命的火花。我们作为育马者的故事始于她的到来，她将永远在我们心中占据特殊的位置。"
    },
    "dreaming": {
      "title": "继续追梦的灵感",
      "body": "展望未来让我们充满兴奋。我一生都带着这个梦想，从不敢想象它会如此快地成为现实。然而我们就在这里，有这么多新的梦想等待展开。新的马匹、新的里程碑、新的篇章等待书写。当我想到那个曾经无法离开祖父母马匹的小女孩时，我知道她会为我们正在建造的一切感到骄傲。未来充满无限可能，我们已准备好拥抱每一个。"
    },
    "testimonial": {
      "quote": "他们说有些梦想太大，无法实现。我曾经相信他们。现在我每天醒来都被我曾经渴望的一切所包围。"
    },
    "moments": {
      "title": "精彩瞬间"
    }
  },
  "metadata": {
    "title": "Secret Arabians",
    "description": "\u57f9\u80b2\u6fc0\u52b1\u4e16\u754c\u7684\u975e\u51e1\u963f\u62c9\u4f2f\u9a6c\u3002\u81f4\u529b\u4e8e\u57f9\u80b2\u54c1\u8d28\u5353\u8d8a\u7684\u963f\u62c9\u4f2f\u9a6c\u7684\u9ad8\u7aef\u80b2\u9a6c\u8ba1\u5212\u3002"
  }
}
